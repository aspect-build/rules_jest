import %workspace%/tools/preset.bazelrc

# //example/custom_sequencer:case2_test target sets `auto_configure_test_sequencer = False` which
# causes the following error on Bazel 7 unless --noincompatible_check_sharding_support is
# ERROR: Testing //example/custom_sequencer:case2_test (shard 2 of 2) failed: Sharding requested,
# but the test runner did not advertise support for it by touching TEST_SHARD_STATUS_FILE. Either
# remove the 'shard_count' attribute, use a test runner that supports sharding or temporarily disable
# this check via --noincompatible_check_sharding_support.
test --noincompatible_check_sharding_support

# rules_js/rules_jest need the runfiles tree physically materialized (real node_modules
# layout + jest resolving its relative --config path). On Windows Bazel defaults to a
# manifest-only runfiles and won't lay out the tree, so tests can't find their config.
# Enable symlinks and force the runfiles tree on Windows (no-ops elsewhere).
# Relies on --enable_platform_specific_config (set in tools/preset.bazelrc).
startup --windows_enable_symlinks
common:windows --enable_runfiles
common:windows --build_runfile_links

# Coverage
# https://github.com/bazelbuild/bazel/blob/e3e4d61b2c2b241d0426ea20143b8a07d6fadfcd/tools/test/collect_cc_coverage.sh#L30
common:ci --experimental_fetch_all_coverage_outputs
common:ci --test_env=COVERAGE_GCOV_PATH=/usr/bin/gcov

# Build without the bytes
common:ci --remote_download_outputs=minimal
common:ci --nobuild_runfile_links

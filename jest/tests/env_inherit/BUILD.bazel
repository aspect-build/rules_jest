load("//jest:defs.bzl", "jest_test")

jest_test(
    name = "test",
    data = ["env_inherit.test.js"],
    # Only vars actually set in the host env are inherited; the rest are ignored.
    # LANG is present on Unix, OS on Windows, so the test sees one of them.
    env_inherit = [
        "LANG",
        "OS",
    ],
    node_modules = "//:node_modules",
)
